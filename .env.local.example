# Copy to .env.local and fill in. None of these are required for the site to run.

# Public site URL (used for SEO metadata, robots, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://mahansigdel.com.np

# Spotify "now playing" card (src/app/api/now-playing).
# Mint the refresh token once with: node scripts/spotify-refresh-token.mjs
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
